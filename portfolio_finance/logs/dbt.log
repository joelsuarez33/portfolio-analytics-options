    LOWER(tipo_opcion) AS tipo,
    CASE 
        WHEN strike_raw > 20000 THEN strike_raw / 10 
        ELSE strike_raw 
    END AS strike,
    mes_vencimiento,
    precio,
    volumen,
    ingest_timestamp
FROM parsed_tickers
WHERE precio > 0 
  AND volumen > 0;


